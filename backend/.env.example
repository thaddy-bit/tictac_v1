# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tictac_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# MTN MOMO API Configuration
MOMO_PRIMARY_KEY=your_momo_primary_key_here
MOMO_SECONDARY_KEY=your_momo_secondary_key_here
MOMO_MERCHANT_UUID=your_merchant_uuid_here
MOMO_CALLBACK_HOST=http://localhost:5000
MOMO_RETURN_URL=http://localhost:3000/payment/success
MOMO_CANCEL_URL=http://localhost:3000/payment/cancel

# Server Configuration
PORT=5000
NODE_ENV=development
